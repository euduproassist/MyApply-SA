rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. STUDENTS / USERS COLLECTION
    match /users/{userId} {
      // Students can read their own profile
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Students can create their own profile during registration
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // Students can update their own data (pin, verification status, etc.)
      allow update: if request.auth != null && request.auth.uid == userId;
    }

    // 2. MAIL COLLECTION (For Firebase Email Extension)
    match /mail/{mailId} {
      allow read: if false; 
      // Students can only send mail if the 'to' field matches their authenticated email
      allow write: if request.auth != null && (
        request.resource.data.to == request.auth.token.email || 
        request.resource.data.to == request.auth.email
      );
    }
    
  }
}
